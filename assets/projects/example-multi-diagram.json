{
  "name": "多流程图项目示例",
  "version": "2.0.0",
  "description": "演示多流程图项目功能：包含检测流程和预处理流程两个独立的Diagram",
  "author": "VisionFlow",
  "created_at": "2026-06-04T00:00:00",
  "modified_at": "2026-06-04T00:00:00",
  "selected_diagram_index": 0,
  "diagrams": [
    {
      "id": "multi-d1",
      "name": "边缘检测流程",
      "description": "图像源 → Canny边缘检测",
      "width": 800.0,
      "height": 600.0,
      "location": "0,0",
      "workflow": {
        "nodes": [
          {"id": "s1", "type": "SrcImageFilesNodeData", "name": "输入图像", "x": 100.0, "y": 150.0, "properties": {}},
          {"id": "c1", "type": "Canny", "name": "Canny边缘", "x": 380.0, "y": 150.0, "properties": {"threshold1": 50.0, "threshold2": 150.0}}
        ],
        "links": [
          {"id": "l1", "from_node": "s1", "from_port": 0, "to_node": "c1", "to_port": 0}
        ]
      }
    },
    {
      "id": "multi-d2",
      "name": "预处理流程",
      "description": "图像源 → 灰度转换 → 高斯模糊 → 二值化",
      "width": 1000.0,
      "height": 600.0,
      "location": "0,0",
      "workflow": {
        "nodes": [
          {"id": "s2", "type": "SrcImageFilesNodeData", "name": "输入图像", "x": 100.0, "y": 150.0, "properties": {}},
          {"id": "cv2", "type": "CvtColor", "name": "转灰度", "x": 340.0, "y": 150.0, "properties": {"color_code": "BGR2GRAY"}},
          {"id": "gb2", "type": "GaussianBlur", "name": "高斯模糊", "x": 560.0, "y": 150.0, "properties": {"ksize": 5}},
          {"id": "th2", "type": "Threshold", "name": "二值化", "x": 780.0, "y": 150.0, "properties": {"thresh": 127.0, "threshold_type": "Otsu"}}
        ],
        "links": [
          {"id": "l2a", "from_node": "s2", "from_port": 0, "to_node": "cv2", "to_port": 0},
          {"id": "l2b", "from_node": "cv2", "from_port": 0, "to_node": "gb2", "to_port": 0},
          {"id": "l2c", "from_node": "gb2", "from_port": 0, "to_node": "th2", "to_port": 0}
        ]
      }
    }
  ],
  "templates": []
}
